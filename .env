# Repo-level environment file for CI lab
# The bootstrap script will automatically generate tokens using these credentials.
GITLAB_URL=http://gitlab
TEAMCITY_URL=http://teamcity:8111

# GitLab root password (set this to auto-configure GitLab on first boot)
GITLAB_ROOT_PASSWORD=changeme123

# Tokens will be auto-generated - no manual configuration needed
# GITLAB_TOKEN and TEAMCITY_TOKEN will be created by bootstrap.py
